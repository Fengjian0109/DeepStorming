{
  "name": "@deepstorming/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "DeepStorming desktop shell",
  "author": "DeepStorming contributors",
  "productName": "DeepStorming",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:dir": "electron-vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "dependencies": {
    "@deepstorming/application": "workspace:*",
    "@deepstorming/contracts": "workspace:*",
    "@deepstorming/domain": "workspace:*",
    "@deepstorming/infrastructure": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@deepstorming/testkit": "workspace:*",
    "@swc/core": "1.15.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "vite": "7.3.6"
  }
}
