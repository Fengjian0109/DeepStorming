{
  "name": "deepstorming",
  "version": "0.0.0",
  "private": true,
  "description": "AI-powered Socratic learning and deep paper reading desktop app",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.7.0 <12"
  },
  "scripts": {
    "dev": "pnpm --filter @deepstorming/desktop dev",
    "build": "pnpm --filter @deepstorming/desktop build",
    "package:dir": "node scripts/package-dir.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/test-e2e.mjs",
    "test:e2e:deepseek": "node scripts/test-e2e.mjs --config playwright.real-deepseek.config.ts",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "pdf-lib": "1.17.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
